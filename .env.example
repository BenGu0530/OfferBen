# ------------------------------------------------------------------
# OfferBen environment variables
# Copy this file to apps/web/.env.local and fill in your values.
# ------------------------------------------------------------------

# --- AI provider (pick one) ---
# AI_PROVIDER selects the backend. Default "gemini". Set "openai" to use ANY
# OpenAI-compatible endpoint (OpenAI, Groq, OpenRouter, DeepSeek, local Ollama,
# or your own fine-tuned model). Swapping models is an env change, not code.
# AI_PROVIDER=gemini

# --- Gemini (used when AI_PROVIDER=gemini) ---
# Server-side only. NEVER prefix with NEXT_PUBLIC_ (would leak the key to the browser).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_google_gemini_api_key
# Optional. Defaults to gemini-2.5-flash. Any Gemini model id works.
GEMINI_MODEL=gemini-2.5-flash

# --- OpenAI-compatible (used when AI_PROVIDER=openai) ---
# AI_API_KEY = key for the chosen service. AI_MODEL = the model id. AI_BASE_URL
# = the service's base url (omit for OpenAI). Examples:
#   Groq:       AI_BASE_URL=https://api.groq.com/openai/v1   AI_MODEL=llama-3.3-70b-versatile
#   OpenRouter: AI_BASE_URL=https://openrouter.ai/api/v1     AI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#   Ollama:     AI_BASE_URL=http://localhost:11434/v1        AI_MODEL=llama3.1   AI_API_KEY=ollama
# AI_API_KEY=
# AI_MODEL=
# AI_BASE_URL=

# --- Google Drive sync (OPTIONAL) ---
# Lets each user sync their profile to THEIR OWN Google Drive (least-privilege
# drive.file scope: the app only ever sees the one offerben-data.json it creates).
# Leave blank to keep the app fully local. This is a PUBLIC client id (safe to ship);
# it is NOT a secret. Create an OAuth 2.0 Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials and add your origin
# (e.g. http://localhost:3000) to "Authorized JavaScript origins".
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# Optional: enables "Import resume from Google Drive" (Google Picker). Create an
# API key at https://console.cloud.google.com/apis/credentials and enable the
# "Google Picker API". Public key (safe to ship); restrict it to your domain.
# NEXT_PUBLIC_GOOGLE_API_KEY=AIzaSy...

# --- Supabase (OPTIONAL for the MVP) ---
# Leave blank to run fully local (profile is stored in the browser's localStorage).
# Fill these in to enable cloud persistence + the multi-user data model (requires Supabase Auth).
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
