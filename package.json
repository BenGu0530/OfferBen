{
  "name": "offerben",
  "version": "0.1.0",
  "private": true,
  "description": "OfferBen - AI job-application copilot (resume tailoring MVP). Offer Max-style, monorepo.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @offerben/web",
    "build": "npm run build -w @offerben/web",
    "start": "npm run start -w @offerben/web",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
